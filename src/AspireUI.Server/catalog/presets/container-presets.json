    "env": [
      [
        "WEBUI_PORT",
        "8080"
      ]
    ],
    "volumes": [
      [
        "config",
        "/config"
      ]
    ],
    "bindMounts": [
      [
        "qbittorrent/qBittorrent.conf",
        "/config/qBittorrent/qBittorrent.conf"
      ]
    ],
    "files": [
      {
        "name": "qbittorrent/qBittorrent.conf",
        "content": "[LegalNotice]\nAccepted=true\n\n[Preferences]\nWebUI\\HostHeaderValidation=false\nWebUI\\CSRFProtection=false\nWebUI\\Username=admin\nWebUI\\Password_PBKDF2=\"@ByteArray(ASNFZ4mrze8BI0VniavN7w==:2eudnLCDJryVCeZQf9qr7NAUBmebSO3e9/32HTM945ugU8DM74Jj2MyIr1YSq0sOMwASMCn0emH3SB5ZbeKR4Q==)\"\n"
